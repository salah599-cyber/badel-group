# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Neon Postgres (add via Vercel Storage → Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Vercel Blob (private — served via /api/media)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Clerk Webhook (Clerk Dashboard → Webhooks → user.created → /api/webhooks/clerk)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Instagram feed (Meta Developer → Instagram Graph API)
NEXT_PUBLIC_INSTAGRAM_HANDLE=your_handle
INSTAGRAM_ACCESS_TOKEN=
